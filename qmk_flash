#!/usr/bin/sh

QMK_HOME="/usr/lib/qmk_firmware"

keyboard_name=$1
if [ -z $keyboard_name ]; then
    read -p "Enter keyboard name: " keyboard_name
fi
keyboard_dir=$(find $QMK_HOME/keyboards -type d -name $keyboard_name)
config_dir=$(find ./ -type d -name $keyboard_name)

if [ -z $keyboard_dir ]; then
    echo "error: keyboard not found"
    exit 1
fi

if [ -z $config_dir ]; then
    echo "error: $keyboard_name not found"
    exit 1
fi

echo "keyboard selected: $keyboard_dir"

config_name=$2
if [ -z $config_name ]; then
    read -p "enter config name: " config_name
fi

while true; do

    if [ -d $config_dir/keymaps/$config_name ]; then
        echo "config found: $config_dir/keymaps/$config_name"
        read -p "overwrite? (y/n) " yn
    fi

    case $yn in
        [Yy]*) echo "overwriting $config_dir/keymaps/$config_name"; return 0  ;;
        [Nn]*) read -p "enter config name: " config_name ;;
    esac
done

exit 0
# check if local dir exists
if [ ! -d "$config_dir/$config_name" ]; then
    echo "Config '$1' not found"
fi

cp ./bridge75/keymaps/$name/keymap.c $DIR/keymaps/$name

qmk flash -kb shortcut/bridge75 -km $1
